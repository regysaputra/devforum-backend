{
  "name": "dev-forum",
  "version": "1.0.0",
  "description": "RESTful API for devforum application",
  "license": "ISC",
  "author": "Regy Saputra",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "migrate": "node-pg-migrate",
    "migrate:prod": "node-pg-migrate --envPath .env",
    "migrate:dev": "node-pg-migrate --envPath .development.env",
    "migrate:test": "node-pg-migrate --envPath .test.env",
    "test": "jest --setupFiles dotenv/config -i",
    "start": "node src/app.js",
    "dev:app": "cross-env NODE_ENV=development nodemon src/app.js",
    "dev:worker": "cross-env NODE_ENV=development nodemon src/worker.js",
    "test:watch": "jest --watchAll --coverage --setupFiles dotenv/config -i",
    "test:applications": "jest --setupFiles dotenv/config --testPathPattern=src/Applications/ -i",
    "test:commons": "jest --setupFiles dotenv/config --testPathPattern=src/Commons/ -i",
    "test:domains": "jest --setupFiles dotenv/config --testPathPattern=src/Domains/ -i",
    "test:repository": "jest --setupFiles dotenv/config --testPathPattern=src/Infrastructures/repository -i",
    "test:http": "jest --setupFiles dotenv/config --testPathPattern=src/Infrastructures/http -i",
    "doc": "redocly bundle swagger/index.yaml --output swagger/index.json"
  },
  "dependencies": {
    "awilix": "^12.1.0",
    "awilix-express": "^10.0.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "twilio": "^5.12.2",
    "ua-parser-js": "^2.0.9",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "jest": "^30.2.0",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "testcontainers": "^11.12.0"
  }
}
